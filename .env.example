COMPOSE_PROJECT_NAME=dailyflow

# App
PORT=3000
NODE_ENV=production
FRONTEND_URL=http://localhost
COOKIE_SECURE=false

# Database
DB_HOST=db
DB_PORT=3306
DB_USER=dailyflow
DB_PASS=changeme
DB_NAME=dailyflow

# Auth
JWT_SECRET=change-me-to-a-32-char-secret

# Asana OAuth
ASANA_CLIENT_ID=your_asana_client_id
ASANA_CLIENT_SECRET=your_asana_client_secret
ASANA_CALLBACK_URL=http://localhost/api/auth/asana/callback

# Ollama (local LLM)
# OLLAMA_BASE_URL is overridden by docker-compose to http://ollama:11434
# Change only when running the API outside Docker or using a remote Ollama instance
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
